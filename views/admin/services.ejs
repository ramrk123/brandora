<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <aside class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-header">
      <a href="/admin/dashboard" class="sidebar-logo" style="display: flex; align-items: center; text-decoration: none; gap: 8px;">
        <div style="width: 32px; height: 32px; border-radius: 50%; background: #0F0F0F; border: 2px solid #F5A623; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 8px rgba(245, 166, 35, 0.3);">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
             <path d="M22 7L13.5 15.5 8.5 10.5 2 17" stroke="#FFFFFF"/>
             <path d="M16 7h6v6" stroke="#F5A623"/>
          </svg>
        </div>
        <span style="font-family: 'Outfit', sans-serif; font-size: 20px; font-weight: 900; letter-spacing: 0.5px;">
          <span style="color: #FFFFFF;">BRAND</span><span style="color: #F5A623;">DIGIX</span>
        </span>
      </a>
      <button class="sidebar-close" id="sidebarClose"><i data-lucide="x"></i></button>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="sidebar-link"><i data-lucide="layout-dashboard"></i><span>Dashboard</span></a>
      <a href="/admin/bookings" class="sidebar-link"><i data-lucide="calendar"></i><span>Bookings</span></a>
      <a href="/admin/customers" class="sidebar-link"><i data-lucide="users"></i><span>Customers</span></a>
      <a href="/admin/services" class="sidebar-link <%= currentPage === 'services' ? 'active' : '' %>"><i data-lucide="layers"></i><span>Services</span></a>
      <a href="/admin/messages" class="sidebar-link"><i data-lucide="mail"></i><span>Messages</span></a>
      <a href="/admin/content" class="sidebar-link"><i data-lucide="file-text"></i><span>Content</span></a>
      <div class="sidebar-divider"></div>
      <a href="/" class="sidebar-link" target="_blank"><i data-lucide="external-link"></i><span>View Website</span></a>
      <a href="/admin/logout" class="sidebar-link logout"><i data-lucide="log-out"></i><span>Logout</span></a>
    </nav>
  </aside>

  <div class="admin-main">
    <header class="admin-header">
      <button class="sidebar-toggle" id="sidebarToggle"><i data-lucide="menu"></i></button>
      <h2 class="admin-page-title">Services Management</h2>
      <div class="admin-header-right">
        <span class="admin-welcome"><strong><%= admin.name %></strong></span>
        <div class="admin-avatar"><%= admin.name.charAt(0).toUpperCase() %></div>
      </div>
    </header>

    <div class="admin-content">
      <div class="admin-toolbar">
        <button class="btn btn-primary" onclick="openServiceModal()">
          <i data-lucide="plus"></i> Add New Service
        </button>
      </div>

      <div class="admin-card">
        <div class="admin-card-header">
          <h3>All Services (<%= services.length %>)</h3>
        </div>
        <div class="admin-card-body">
          <div class="table-responsive">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Order</th>
                  <th>Icon</th>
                  <th>Name</th>
                  <th>Description</th>
                  <th>Price</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% services.forEach(s => { %>
                  <tr id="service-row-<%= s._id %>">
                    <td><%= s.sort_order %></td>
                    <td><i data-lucide="<%= s.icon %>"></i></td>
                    <td><strong><%= s.name %></strong></td>
                    <td class="desc-cell"><%= s.description.substring(0, 80) %>...</td>
                    <td><%= s.price_display %></td>
                    <td><span class="status-badge <%= s.is_active ? 'status-completed' : 'status-cancelled' %>"><%= s.is_active ? 'Active' : 'Inactive' %></span></td>
                    <td>
                      <div class="action-btns">
                        <button class="action-btn edit" onclick='editService(<%= JSON.stringify(s) %>)' title="Edit">
                          <i data-lucide="edit"></i>
                        </button>
                        <button class="action-btn delete" onclick="deleteService('<%= s._id %>')" title="Delete">
                          <i data-lucide="trash-2"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Service Modal -->
  <div class="modal-overlay" id="serviceModal">
    <div class="modal modal-lg">
      <div class="modal-header">
        <h3 id="serviceModalTitle">Add New Service</h3>
        <button class="modal-close" onclick="closeServiceModal()"><i data-lucide="x"></i></button>
      </div>
      <form id="serviceForm" onsubmit="saveService(event)">
        <input type="hidden" id="serviceId" value="">
        <div class="form-group">
          <label>Service Name</label>
          <input type="text" id="serviceName" required placeholder="e.g. Logo Creation">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Icon (Lucide icon name)</label>
            <input type="text" id="serviceIcon" placeholder="e.g. palette, code, layout">
          </div>
          <div class="form-group">
            <label>Price Display</label>
            <input type="text" id="servicePrice" placeholder="e.g. Contact for Quote">
          </div>
        </div>
        <div class="form-group">
          <label>Description</label>
          <textarea id="serviceDesc" rows="3" required placeholder="Describe the service..."></textarea>
        </div>
        <div class="form-group">
          <label>Benefits (separate with |)</label>
          <textarea id="serviceBenefits" rows="2" placeholder="Benefit 1|Benefit 2|Benefit 3"></textarea>
        </div>
        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" id="serviceActive" checked> Active
          </label>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline" onclick="closeServiceModal()">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Service</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/admin.js"></script>
</body>
</html>
