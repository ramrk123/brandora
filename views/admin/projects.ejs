<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#0F0F0F">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <aside class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-header">
      <a href="/admin/dashboard" class="sidebar-logo" style="display: flex; align-items: center; text-decoration: none; gap: 8px;">
        <div style="width: 32px; height: 32px; border-radius: 50%; background: #0F0F0F; border: 2px solid #F5A623; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 8px rgba(245, 166, 35, 0.3);">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
             <path d="M22 7L13.5 15.5 8.5 10.5 2 17" stroke="#FFFFFF"/>
             <path d="M16 7h6v6" stroke="#F5A623"/>
          </svg>
        </div>
        <span style="font-family: 'Outfit', sans-serif; font-size: 20px; font-weight: 900; letter-spacing: 0.5px;">
          <span style="color: #FFFFFF;">BRAND</span><span style="color: #F5A623;">DIGIX</span>
        </span>
      </a>
      <button class="sidebar-close" id="sidebarClose"><i data-lucide="x"></i></button>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="sidebar-link"><i data-lucide="layout-dashboard"></i><span>Dashboard</span></a>
      <a href="/admin/bookings" class="sidebar-link"><i data-lucide="calendar"></i><span>Bookings</span></a>
      <a href="/admin/customers" class="sidebar-link"><i data-lucide="users"></i><span>Customers</span></a>
      <a href="/admin/services" class="sidebar-link"><i data-lucide="layers"></i><span>Services</span></a>
      <a href="/admin/projects" class="sidebar-link active"><i data-lucide="image"></i><span>Projects</span></a>
      <a href="/admin/messages" class="sidebar-link"><i data-lucide="mail"></i><span>Messages</span></a>
      <a href="/admin/content" class="sidebar-link"><i data-lucide="file-text"></i><span>Content</span></a>
      <div class="sidebar-divider"></div>
      <a href="/" class="sidebar-link" target="_blank"><i data-lucide="external-link"></i><span>View Website</span></a>
      <a href="/admin/logout" class="sidebar-link logout"><i data-lucide="log-out"></i><span>Logout</span></a>
    </nav>
  </aside>

  <div class="admin-main">
    <header class="admin-header">
      <button class="sidebar-toggle" id="sidebarToggle"><i data-lucide="menu"></i></button>
      <h2 class="admin-page-title">Portfolio Projects</h2>
      <div class="admin-header-right">
        <span class="admin-welcome"><strong><%= admin.name %></strong></span>
        <div class="admin-avatar"><%= admin.name.charAt(0).toUpperCase() %></div>
      </div>
    </header>

    <div class="admin-content">
      <div class="admin-toolbar">
        <button class="btn btn-primary" onclick="document.getElementById('uploadModal').classList.add('active'); lucide.createIcons();">
          <i data-lucide="upload-cloud"></i> Upload New Work
        </button>
      </div>

      <div class="admin-card">
        <div class="admin-card-header">
          <h3>Your Recent Works (<%= projects.length %>)</h3>
        </div>
        <div class="admin-card-body">
          <div class="table-responsive">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Preview</th>
                  <th>Project Title</th>
                  <th>Category</th>
                  <th>Date</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% projects.forEach(p => { %>
                  <tr id="project-row-<%= p.id %>">
                    <td><img src="<%= p.image_url %>" style="width: 70px; height: 50px; object-fit: cover; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1)"></td>
                    <td><strong><%= p.title %></strong></td>
                    <td><span class="badge"><%= p.service_name %></span></td>
                    <td class="text-muted"><%= new Date(p.created_at).toLocaleDateString() %></td>
                    <td>
                      <button class="action-btn delete" onclick="deleteProject(<%= p.id %>)" title="Delete">
                        <i data-lucide="trash-2"></i>
                      </button>
                    </td>
                  </tr>
                <% }) %>
                <% if(projects.length === 0) { %>
                  <tr>
                    <td colspan="5" style="text-align:center; padding: 60px; color:#9E9E9E;">No projects uploaded yet. Start sharing your work!</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Upload Modal -->
  <div class="modal-overlay" id="uploadModal">
    <div class="modal">
      <div class="modal-header">
        <h3>Upload Project</h3>
        <button class="modal-close" onclick="document.getElementById('uploadModal').classList.remove('active')"><i data-lucide="x"></i></button>
      </div>
      <form action="/admin/projects" method="POST" enctype="multipart/form-data" style="padding: 20px;">
        <div class="form-group">
          <label>Project Title</label>
          <input type="text" name="title" class="admin-input" required placeholder="e.g. Modern Tech Logo">
        </div>
        <div class="form-group">
          <label>Service Category</label>
          <select name="service_name" class="admin-input" required style="background: #1A1A1A; border: 1px solid rgba(255,255,255,0.1); color: white; padding: 12px;">
            <% services.forEach(s => { %>
              <option value="<%= s.name %>" style="color: black;"><%= s.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Select Work Image</label>
          <input type="file" name="image" accept="image/*" class="admin-input" required style="padding: 10px;">
        </div>
        <div class="modal-footer" style="padding-top: 20px;">
          <button type="button" class="btn btn-outline" onclick="document.getElementById('uploadModal').classList.remove('active')">Cancel</button>
          <button type="submit" class="btn btn-primary">Start Upload</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/admin.js"></script>
  <script>
    async function deleteProject(id) {
      if(!confirm('Permanently delete this work?')) return;
      try {
        const res = await fetch('/admin/projects/' + id, { method: 'DELETE' });
        if(res.ok) {
          document.getElementById('project-row-' + id).remove();
          showToast('Project deleted successfully');
        }
      } catch(e) { showToast('Error deleting', 'error'); }
    }
  </script>
</body>
</html>
