<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- SEO & Primary Meta Tags -->
  <title><%= typeof title !== 'undefined' ? title : 'BRANDDIGIX - Expert Logo Design & Creative Agency' %></title>
  <meta name="title" content="<%= typeof title !== 'undefined' ? title : 'BRANDDIGIX - We Design Your Digital Identity' %>">
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'BRANDDIGIX is a premium creative agency specializing in logo design, UI/UX, website development, and custom branding services. We build digital identities that perform.' %>">
  <meta name="keywords" content="logo design, website development, creative agency india, UI/UX design, brand identity, graphic design services">
  <meta name="author" content="BRANDDIGIX">
  <link rel="canonical" href="https://branddigix-com.onrender.com/">

  <!-- Open Graph / Facebook (Social Media Sharing) -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://branddigix-com.onrender.com/">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'BRANDDIGIX - Expert Logo Design & Creative Agency' %>">
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Elevate your brand with premium logo design and expert web development from BRANDDIGIX.' %>">
  <meta property="og:image" content="https://branddigix-com.onrender.com/images/og-image.jpg">

  <!-- Twitter Card -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="https://branddigix-com.onrender.com/">
  <meta property="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'BRANDDIGIX - Expert Logo Design & Creative Agency' %>">
  <meta property="twitter:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Elevate your brand with premium logo design and expert web development.' %>">
  <meta property="twitter:image" content="https://branddigix-com.onrender.com/images/og-image.jpg">

  <!-- Mobile & Theme -->
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
  
  <!-- Stylesheets -->
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/animations.css">
</head>
<body>
  <%- include('../partials/header') %>
  
  <main>
    <%- body %>
  </main>

  <%- include('../partials/footer') %>
  
  <script src="/js/animations.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
